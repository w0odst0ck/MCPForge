# ── MCP Server Template 环境变量配置 ────────────────────────
# 复制为 .env 后按需修改

# 项目
PROJECT_NAME=mcp-server-template
ENVIRONMENT=dev

# 服务器
HOST=127.0.0.1
PORT=8000
RELOAD=true

# CORS（逗号分隔）
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# 数据库（可选）
# DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/mcp_db?charset=utf8mb4

# 日志
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
